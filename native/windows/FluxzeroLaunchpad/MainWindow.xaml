<Window
    x:Class="Fluxzero.Launchpad.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fluxzero Launchpad">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <Style x:Key="SectionBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style x:Key="RowDividerStyle" TargetType="Border">
                <Setter Property="Height" Value="1" />
                <Setter Property="Margin" Value="0,4" />
                <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
            </Style>
        </Grid.Resources>

        <ScrollViewer>
            <StackPanel
                Padding="40,24,40,28"
                Width="700"
                HorizontalAlignment="Center"
                Spacing="14">

                <TextBlock Text="New Fluxzero Project" Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border Style="{StaticResource SectionBorderStyle}" Padding="14">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="150,*" ColumnSpacing="16">
                            <TextBlock Text="Name" VerticalAlignment="Center" />
                            <TextBox
                                x:Name="ProjectNameBox"
                                Grid.Column="1"
                                PlaceholderText="Enter project name"
                                TextChanged="ProjectNameBox_TextChanged" />
                        </Grid>

                        <Border Style="{StaticResource RowDividerStyle}" />

                        <Grid ColumnDefinitions="150,*" ColumnSpacing="16">
                            <TextBlock Text="Description" VerticalAlignment="Top" Margin="0,8,0,0" />
                            <TextBox
                                x:Name="PromptBox"
                                Grid.Column="1"
                                AcceptsReturn="True"
                                MinHeight="142"
                                PlaceholderText="Describe what you want to build"
                                TextWrapping="Wrap" />
                        </Grid>

                        <Border Style="{StaticResource RowDividerStyle}" />

                        <Grid ColumnDefinitions="150,*,Auto" ColumnSpacing="16">
                            <TextBlock
                                Text="Open project in"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox
                                x:Name="OpenDestinationBox"
                                Grid.Column="2"
                                MinWidth="170"
                                HorizontalAlignment="Right"
                                SelectionChanged="OpenDestinationBox_SelectionChanged" />
                        </Grid>

                        <Border Style="{StaticResource RowDividerStyle}" />

                        <Expander Header="Advanced options">
                            <Grid
                                Padding="0,10,0,0"
                                ColumnDefinitions="150,*"
                                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                RowSpacing="10"
                                ColumnSpacing="16">
                                <TextBlock
                                    Text="Location"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox x:Name="LocationBox" />
                                    <Button Grid.Column="1" Content="Choose" Click="ChooseLocationButton_Click" />
                                </Grid>

                                <TextBlock
                                    Grid.Row="1"
                                    Text="Template"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="TemplateBox" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" MinWidth="220" />

                                <TextBlock
                                    Grid.Row="2"
                                    Text="Build system"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="BuildBox" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" MinWidth="220" SelectedIndex="0">
                                    <ComboBoxItem Content="Maven" Tag="maven" />
                                    <ComboBoxItem Content="Gradle" Tag="gradle" />
                                </ComboBox>

                                <TextBlock
                                    Grid.Row="3"
                                    Text="Group ID"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox x:Name="GroupBox" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" MinWidth="220" Text="com.example" />

                                <TextBlock
                                    Grid.Row="4"
                                    Text="Artifact ID"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox x:Name="ArtifactBox" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" MinWidth="220" />

                                <TextBlock
                                    Grid.Row="5"
                                    Text="Package"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBox x:Name="PackageBox" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" MinWidth="220" Text="com.example.app" />

                                <TextBlock
                                    x:Name="GitLabel"
                                    Grid.Row="6"
                                    Text="Git"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <CheckBox
                                    x:Name="GitBox"
                                    Grid.Row="6"
                                    Grid.Column="1"
                                    Content="Initialize repository"
                                    IsChecked="True" />
                            </Grid>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionBorderStyle}" Padding="12">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                        <TextBlock x:Name="StatusText" Visibility="Collapsed" />
                        <ProgressRing
                            x:Name="BusyRing"
                            Grid.Column="1"
                            Width="18"
                            Height="18"
                            IsActive="False"
                            Visibility="Collapsed" />
                        <Button
                            x:Name="PrimaryActionButton"
                            Grid.Column="2"
                            MinWidth="112"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="PrimaryActionButton_Click" />
                    </Grid>
                </Border>

                <TextBlock
                    Margin="0,16,0,0"
                    Text="Recent projects"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border Style="{StaticResource SectionBorderStyle}" Padding="8" MinHeight="58">
                    <ListView x:Name="ProjectsList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="6" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                                    <FontIcon Grid.Column="0" Glyph="&#xE8B7;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <TextBlock
                                            Text="{Binding DisplayPath}"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{Binding Path}" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Tag="{Binding}" Click="DeleteProject_Click" ToolTipService.ToolTip="Delete project">
                                        <FontIcon Glyph="&#xE74D;" />
                                    </Button>
                                    <Button Grid.Column="3" Tag="{Binding}" Click="CopyPrompt_Click" ToolTipService.ToolTip="Copy prompt">
                                        <FontIcon Glyph="&#xE8C8;" />
                                    </Button>
                                    <Button Grid.Column="4" Tag="{Binding}" Click="OpenProjectFolder_Click" ToolTipService.ToolTip="Open folder">
                                        <FontIcon Glyph="&#xE838;" />
                                    </Button>
                                    <Button Grid.Column="5" Tag="{Binding}" Click="OpenProjectCursor_Click" ToolTipService.ToolTip="Open in Cursor">
                                        <Image Width="16" Height="16" Stretch="Uniform">
                                            <Image.Source>
                                                <SvgImageSource UriSource="ms-appx:///Assets/CursorCube.svg" />
                                            </Image.Source>
                                        </Image>
                                    </Button>
                                    <Button Grid.Column="6" Tag="{Binding}" Click="OpenProjectClaude_Click" ToolTipService.ToolTip="Open in Claude Code">
                                        <Image Width="16" Height="16" Stretch="Uniform">
                                            <Image.Source>
                                                <SvgImageSource UriSource="ms-appx:///Assets/ClaudeCodeMark.svg" />
                                            </Image.Source>
                                        </Image>
                                    </Button>
                                    <Button Grid.Column="7" Tag="{Binding}" Click="OpenProjectCodex_Click" ToolTipService.ToolTip="Open in Codex">
                                        <Image Width="16" Height="16" Stretch="Uniform">
                                            <Image.Source>
                                                <SvgImageSource UriSource="ms-appx:///Assets/CodexIcon.svg" />
                                            </Image.Source>
                                        </Image>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
