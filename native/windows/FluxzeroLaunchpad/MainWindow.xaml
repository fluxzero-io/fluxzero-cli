<Window
    x:Class="Fluxzero.Launchpad.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Fluxzero.Launchpad"
    Title="Fluxzero Launchpad">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <AcrylicBrush
                FallbackColor="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                TintColor="{ThemeResource SystemAccentColor}"
                TintLuminosityOpacity="0.08"
                TintOpacity="0.10" />
        </Grid.Background>

        <Grid ColumnDefinitions="280,*">
            <Border
                Padding="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Image Width="40" Height="40" Source="Assets/fluxzero.png" />
                        <StackPanel>
                            <TextBlock Text="Fluxzero" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Launchpad" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Margin="0,22" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Grid.Row="2" Spacing="14">
                        <NavigationViewItem Content="Create" IsSelected="True">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Add" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="Projects">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Folder" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem Content="Upgrades">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Sync" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </StackPanel>

                    <StackPanel Grid.Row="3" VerticalAlignment="Bottom" Spacing="10">
                        <ProgressRing x:Name="BusyRing" Width="22" Height="22" IsActive="False" />
                        <TextBlock
                            x:Name="StatusText"
                            Text="Preparing Fluxzero CLI..."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1">
                <StackPanel Padding="32" Spacing="24">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Fluxzero Launchpad" Style="{ThemeResource TitleTextBlockStyle}" />
                        <TextBlock
                            Text="Generate local Fluxzero projects and move straight into your coding agent."
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="24">
                        <StackPanel Spacing="18">
                            <TextBlock Text="Project" Style="{ThemeResource SubtitleTextBlockStyle}" />

                            <TextBox
                                x:Name="ProjectNameBox"
                                Header="Project name"
                                TextChanged="ProjectNameBox_TextChanged" />

                            <TextBox
                                x:Name="PromptBox"
                                Header="Describe what you want to build"
                                AcceptsReturn="True"
                                MinHeight="140"
                                TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                                <Button
                                    x:Name="OpenCodexButton"
                                    Grid.Column="0"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="OpenCodexButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE950;" />
                                        <TextBlock Text="Open in Codex" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="OpenClaudeButton"
                                    Grid.Column="1"
                                    Click="OpenClaudeButton_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE756;" />
                                        <TextBlock Text="Open in Claude Code" />
                                    </StackPanel>
                                </Button>
                                <HyperlinkButton
                                    Grid.Column="3"
                                    Content="Create only"
                                    Click="CreateOnlyButton_Click" />
                            </Grid>

                            <Expander Header="Advanced options">
                                <Grid Padding="0,12,0,0" ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                                    <TextBlock Grid.Row="0" Text="Location" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBox x:Name="LocationBox" />
                                        <Button Grid.Column="1" Content="Choose" Click="ChooseLocationButton_Click" />
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="Template" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <ComboBox x:Name="TemplateBox" Grid.Row="1" Grid.Column="1" />

                                    <TextBlock Grid.Row="2" Text="Build" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <ComboBox x:Name="BuildBox" Grid.Row="2" Grid.Column="1" SelectedIndex="0">
                                        <ComboBoxItem Content="Maven" Tag="maven" />
                                        <ComboBoxItem Content="Gradle" Tag="gradle" />
                                    </ComboBox>

                                    <TextBlock Grid.Row="3" Text="Group ID" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBox x:Name="GroupBox" Grid.Row="3" Grid.Column="1" Text="com.example" />

                                    <TextBlock Grid.Row="4" Text="Artifact ID" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBox x:Name="ArtifactBox" Grid.Row="4" Grid.Column="1" />

                                    <TextBlock Grid.Row="5" Text="Package" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBox x:Name="PackageBox" Grid.Row="5" Grid.Column="1" Text="com.example.app" />

                                    <TextBlock Grid.Row="6" Text="Git" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <CheckBox x:Name="GitBox" Grid.Row="6" Grid.Column="1" Content="Initialize repository" IsChecked="True" />

                                    <TextBlock Grid.Row="7" Text="CLI" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock x:Name="CliFootnote" Grid.Row="7" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="24">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Recent projects" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <Button Grid.Column="1" Click="RefreshButton_Click">
                                    <FontIcon Glyph="&#xE72C;" />
                                </Button>
                            </Grid>
                            <ListView x:Name="ProjectsList" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:GeneratedProject">
                                        <Grid Padding="8" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="12">
                                            <FontIcon Grid.Column="0" Glyph="&#xE8B7;" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                                <TextBlock Text="{Binding Path}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Tag="{Binding}" Click="OpenProjectCodex_Click" ToolTipService.ToolTip="Open in Codex">
                                                <FontIcon Glyph="&#xE950;" />
                                            </Button>
                                            <Button Grid.Column="3" Tag="{Binding}" Click="OpenProjectClaude_Click" ToolTipService.ToolTip="Open in Claude Code">
                                                <FontIcon Glyph="&#xE756;" />
                                            </Button>
                                            <Button Grid.Column="4" Tag="{Binding}" Click="OpenProjectFolder_Click" ToolTipService.ToolTip="Open folder">
                                                <FontIcon Glyph="&#xE838;" />
                                            </Button>
                                            <Button Grid.Column="5" Tag="{Binding}" Click="CopyPrompt_Click" ToolTipService.ToolTip="Copy prompt">
                                                <FontIcon Glyph="&#xE8C8;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
